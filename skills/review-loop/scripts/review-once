#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: review-once [options]

Choose and optionally run one Codex review command for the current Git checkout.

Options:
  --mode auto|local|base|commit  Review target. Default: auto.
  --base REF                     Integration base for --mode base or auto.
  --commit SHA                   Commit for --mode commit. Default: HEAD.
  --codex-bin PATH               Codex binary. Default: codex.
  --config KEY=VALUE             Pass a Codex config override. Repeatable.
  --output FILE                  Save output to an absolute path outside the worktree.
  --fetch                        Fetch the remote that owns the selected base.
  --dry-run                      Print the selected command, do not run it.
  -h, --help                     Show this help.

Auto mode:
  dirty tree -> codex review --uncommitted
  clean tree with commits ahead of the remote default branch -> codex review --base <base>
  clean tree with no base delta -> codex review --commit HEAD

If dirty and committed work both exist, auto mode prints the base command to run
after the uncommitted phase. The tree does not need to be clean between phases.
EOF
}

die() {
  printf 'review-once: %s\n' "$1" >&2
  exit "${2:-1}"
}

require_value() {
  if [[ $# -lt 2 || -z "$2" || "$2" == --* ]]; then
    printf 'review-once: missing value for %s\n' "$1" >&2
    usage >&2
    exit 2
  fi
}

mode=auto
base_ref=
commit_ref=HEAD
codex_bin=${CODEX_BIN:-codex}
output=${CODEX_REVIEW_OUTPUT:-}
fetch=false
dry_run=false
codex_configs=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode)
      require_value "$@"
      mode=$2
      shift 2
      ;;
    --base)
      require_value "$@"
      base_ref=$2
      shift 2
      ;;
    --commit)
      require_value "$@"
      commit_ref=$2
      shift 2
      ;;
    --codex-bin)
      require_value "$@"
      codex_bin=$2
      shift 2
      ;;
    --config)
      require_value "$@"
      codex_configs+=("$2")
      shift 2
      ;;
    --output)
      require_value "$@"
      output=$2
      shift 2
      ;;
    --fetch)
      fetch=true
      shift
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'review-once: unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

case "$mode" in
  auto|local|base|commit) ;;
  *) die "invalid --mode: $mode" 2 ;;
esac

if ! repo_root=$(git rev-parse --show-toplevel 2>/dev/null); then
  die "not inside a Git worktree"
fi
repo_root=$(cd "$repo_root" && pwd -P)
current_branch=$(git branch --show-current 2>/dev/null || true)

validate_output() {
  local output_dir output_dir_abs output_abs

  [[ "$output" == /* ]] || die "--output must be an absolute path outside the Git worktree" 2
  [[ ! -L "$output" ]] || die "--output must not be a symbolic link" 2

  output_dir=$(dirname "$output")
  [[ -d "$output_dir" ]] || die "--output directory does not exist: $output_dir" 2
  output_dir_abs=$(cd "$output_dir" && pwd -P)
  output_abs="$output_dir_abs/$(basename "$output")"

  case "$output_abs" in
    "$repo_root"|"$repo_root"/*)
      die "--output must be outside the Git worktree: $repo_root" 2
      ;;
  esac

  output=$output_abs
}

if [[ -n "$output" ]]; then
  validate_output
fi

dirty=false
if [[ -n "$(git status --porcelain=v1)" ]]; then
  dirty=true
fi

tracking_remote() {
  [[ -n "$current_branch" ]] || return 1
  git config --get "branch.$current_branch.remote" 2>/dev/null
}

remote_head() {
  local remote=$1
  [[ -n "$remote" && "$remote" != "." ]] || return 1
  git symbolic-ref --quiet --short "refs/remotes/$remote/HEAD" 2>/dev/null
}

choose_base() {
  local remote resolved

  if [[ -n "$base_ref" ]]; then
    printf '%s\n' "$base_ref"
    return 0
  fi

  remote=$(tracking_remote || true)
  if [[ -n "$remote" ]] && resolved=$(remote_head "$remote"); then
    printf '%s\n' "$resolved"
    return 0
  fi

  if [[ "$remote" != "origin" ]] && resolved=$(remote_head origin); then
    printf '%s\n' "$resolved"
    return 0
  fi

  return 1
}

ref_exists() {
  git rev-parse --verify --quiet "$1^{commit}" >/dev/null
}

commits_ahead_of() {
  local ahead
  ref_exists "$1" || return 1
  ahead=$(git rev-list --count "$1..HEAD" 2>/dev/null) || return 1
  [[ "$ahead" != "0" ]]
}

remote_for_ref() {
  local candidate
  [[ "$1" == */* ]] || return 1
  candidate=${1%%/*}
  git remote get-url "$candidate" >/dev/null 2>&1 || return 1
  printf '%s\n' "$candidate"
}

selected_base=
if [[ "$mode" == auto || "$mode" == base ]]; then
  selected_base=$(choose_base || true)
fi

if [[ "$fetch" == true ]]; then
  if [[ "$mode" != auto && "$mode" != base ]]; then
    die "--fetch requires --mode auto or --mode base" 2
  fi
  [[ -n "$selected_base" ]] || die "cannot infer a base to fetch; pass --base REF"
  fetch_remote=$(remote_for_ref "$selected_base" || true)
  [[ -n "$fetch_remote" ]] || die "cannot determine the remote for base: $selected_base"
  if ! git fetch "$fetch_remote" --quiet; then
    die "fetch failed for remote: $fetch_remote"
  fi
fi

if [[ -n "$base_ref" && ( "$mode" == auto || "$mode" == base ) ]] && ! ref_exists "$selected_base"; then
  die "base ref not found: $selected_base"
fi

selected_kind=
case "$mode" in
  local)
    selected_kind=local
    ;;
  base)
    [[ -n "$selected_base" ]] || die "could not resolve comparison base; pass --base REF"
    ref_exists "$selected_base" || die "base ref not found: $selected_base"
    git merge-base HEAD "$selected_base" >/dev/null 2>&1 || die "no merge base with: $selected_base"
    selected_kind=base
    ;;
  commit)
    selected_kind=commit
    ;;
  auto)
    if [[ "$dirty" == true ]]; then
      selected_kind=local
    else
      [[ -n "$selected_base" ]] || die "could not resolve comparison base; pass --base REF or use --mode commit"
      ref_exists "$selected_base" || die "base ref not found: $selected_base"
      if commits_ahead_of "$selected_base"; then
        git merge-base HEAD "$selected_base" >/dev/null 2>&1 || die "no merge base with: $selected_base"
        selected_kind=base
      else
        selected_kind=commit
      fi
    fi
    ;;
esac

review_cmd=("$codex_bin" review)
if [[ ${#codex_configs[@]} -gt 0 ]]; then
  for config in "${codex_configs[@]}"; do
    review_cmd+=(-c "$config")
  done
fi

case "$selected_kind" in
  local)
    review_cmd+=(--uncommitted)
    ;;
  base)
    review_cmd+=(--base "$selected_base")
    ;;
  commit)
    ref_exists "$commit_ref" || die "commit ref not found: $commit_ref"
    review_cmd+=(--commit "$commit_ref")
    ;;
  *)
    die "could not select review target"
    ;;
esac

printf 'review-loop target: %s\n' "$selected_kind"
printf 'branch: %s\n' "${current_branch:-detached}"
if [[ -n "$selected_base" ]]; then
  printf 'base: %s\n' "$selected_base"
fi
printf 'dirty: %s\n' "$dirty"
printf 'review:'
printf ' %q' "${review_cmd[@]}"
printf '\n'

if [[ "$dirty" == true ]]; then
  if [[ -z "$selected_base" ]]; then
    printf 'note: comparison base unresolved; pass --base REF for a committed-work phase if needed.\n'
  elif commits_ahead_of "$selected_base"; then
    printf 'note: committed work also exists; after the local phase run %q --mode base --base %q. The tree need not be clean.\n' "$0" "$selected_base"
  fi
fi

if [[ -n "$output" ]]; then
  printf 'output: %s\n' "$output"
fi

if [[ "$dry_run" == true ]]; then
  exit 0
fi

status_before=$(git status --porcelain=v1)
set +e
if [[ -n "$output" ]]; then
  "${review_cmd[@]}" 2>&1 | tee "$output"
  pipeline_status=("${PIPESTATUS[@]}")
  review_status=${pipeline_status[0]}
  if [[ "$review_status" -eq 0 && "${pipeline_status[1]}" -ne 0 ]]; then
    review_status=${pipeline_status[1]}
  fi
else
  "${review_cmd[@]}"
  review_status=$?
fi
set -e

status_after=$(git status --porcelain=v1)
if [[ "$status_before" != "$status_after" ]]; then
  printf 'warning: Git worktree state changed during review:\n' >&2
  git status --short >&2
fi

exit "$review_status"
